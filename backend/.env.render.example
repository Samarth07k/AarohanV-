# ── Render Backend Environment Variables ─────────────────────────────────────
# Copy these into your Render service's Environment tab.
# Values marked [SECRET] must be entered via the Render dashboard — never commit
# real secrets to version control.

# Database (from your Render PostgreSQL service's connection info)
DB_URL=jdbc:postgresql://<INTERNAL_HOST>:5432/<DB_NAME>
DB_USER=<DB_USER>
DB_PASSWORD=[SECRET]

# JWT — generate a 256-bit Base64 secret:
#   openssl rand -base64 32
JWT_SECRET=[SECRET]
JWT_ACCESS_TTL=900       # 15 minutes
JWT_REFRESH_TTL=604800   # 7 days

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=https://your-app.vercel.app

# Server
SERVER_PORT=8080

# Demo seed — set to false in production once demo data is no longer needed
DEMO_SEED=true
